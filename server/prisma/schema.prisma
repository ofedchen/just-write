generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Prompt {
  id   String @id @default(uuid())
  text String
}

model User {
  id                    String          @id @default(uuid())
  username              String          @unique
  passwordHash          String
  firstname             String          @default("")
  surname               String          @default("")
  profileBio            String          @default("")
  profileFavoriteAuthors String         @default("")
  profileFavoriteGenres String          @default("")
  profileFavoriteBook   String          @default("")
  createdAt             DateTime        @default(now())
  publishedTexts        PublishedText[]
  likes                 Like[]
}

model PublishedText {
  id        String   @id @default(uuid())
  authorId  String
  prompt    String
  text      String
  date      String
  createdAt DateTime @default(now())
  author    User     @relation(fields: [authorId], references: [id], onDelete: Cascade)
  likes     Like[]
}

model Like {
  id              String        @id @default(uuid())
  userId          String
  publishedTextId String
  user            User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  publishedText   PublishedText @relation(fields: [publishedTextId], references: [id], onDelete: Cascade)

  @@unique([userId, publishedTextId])
}
